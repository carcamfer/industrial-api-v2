extends layout

block content
  - pageTitle = 'Reporte Auditoría ISO'
  - currentPage = 'audit'

  .page-header
    .page-header-inner
      div
        .page-breadcrumb
          a(href="/") Inicio
          svg(width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
            polyline(points="9,18 15,12 9,6")
          a(href="/integracion-iso") Integración ISO
          svg(width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
            polyline(points="9,18 15,12 9,6")
          | Reporte Auditoría
        h1.page-title Reporte de Auditoría ISO
        p.page-subtitle Cumplimiento automático con ISO 9001 · IATF 16949 · ISO 27001 · ISO 45001 · IEC 61511 · ISO 55001 · ISO 14001 · ISO 50001 · ISO 28000 · ISO 22301
      .page-actions
        a.btn.btn-outline(href="/dashboard" + (since ? '?since=' + since : ''))
          svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            rect(x="3" y="3" width="7" height="7")
            rect(x="14" y="3" width="7" height="7")
            rect(x="14" y="14" width="7" height="7")
            rect(x="3" y="14" width="7" height="7")
          | Dashboard
        button.btn.btn-outline(type="button" onclick="window.print()")
          svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            polyline(points="6,9 6,2 18,2 18,9")
            path(d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2")
            rect(x="6" y="14" width="12" height="8")
          | Imprimir / PDF

  main
    .audit-header
      h2
        svg(width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:.5rem;vertical-align:middle")
          path(d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z")
          polyline(points="14,2 14,8 20,8")
          line(x1="16" y1="13" x2="8" y2="13")
          line(x1="16" y1="17" x2="8" y2="17")
          polyline(points="10,9 9,9 8,9")
        | Reporte de Auditoría ISO
      p.audit-meta
        | ID: #{report.reportId} &nbsp;|&nbsp;
        | Generado: #{new Date(report.generatedAt).toLocaleString('es-MX')}
        if report.period.from
          |  &nbsp;|&nbsp; Período: #{new Date(report.period.from).toLocaleDateString('es-MX')} – #{new Date(report.period.to).toLocaleDateString('es-MX')}
        span#audit-period

    .summary-grid
      .summary-card.card-total
        h3(id="stat-total")= report.summary.total
        p Total de eventos
      .summary-card.card-compliant
        h3(id="stat-compliant")= report.summary.compliant
        p Conformes
      .summary-card.card-warning
        h3(id="stat-warnings")= report.summary.warnings
        p Advertencias
      .summary-card.card-noncompliant
        h3(id="stat-noncompliant")= report.summary.nonCompliant
        p No conformes

    h3.section-title
      svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
        path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
      | Cumplimiento por Norma ISO

    #by-standard-wrap
      .scrollable(style="max-height:500px")
        each stdData, stdName in report.byStandard
          .standard-block
            .standard-header
              span.standard-name= stdName
              .badges
                span.badge.badge-ok ✓ #{stdData.compliant}
                span.badge.badge-warn ⚠ #{stdData.warnings}
                span.badge.badge-fail ✗ #{stdData.nonCompliant}
            table
              thead
                tr
                  th Cláusula
                  th Título
                  th Conformes
                  th Advertencias
                  th No Conformes
              tbody
                each clause in stdData.clauses
                  tr
                    td= clause.clause
                    td= clause.title
                    td.status-COMPLIANT= clause.compliant
                    td.status-WARNING= clause.warnings
                    td.status-NON_COMPLIANT= clause.nonCompliant

    h3.section-title
      svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
        circle(cx="12" cy="12" r="10")
        line(x1="12" y1="8" x2="12" y2="12")
        line(x1="12" y1="16" x2="12.01" y2="16")
      | Hallazgos Críticos

    #critical-findings-wrap
      if report.criticalFindings.length === 0
        p.no-findings ✅ No se encontraron hallazgos críticos en el período analizado.
      else
        .scrollable
          each finding in report.criticalFindings
            .critical-block
              h4 🚨 #{finding.module.toUpperCase()} — #{finding.asset}
              p
                strong Timestamp:
                | #{new Date(finding.timestamp).toLocaleString('es-MX')}
              p
                strong Normas afectadas:
                | #{finding.standards}
              p
                strong Recomendación:
                | #{finding.recommendation}

    h3.section-title
      svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
        line(x1="8" y1="6" x2="21" y2="6")
        line(x1="8" y1="12" x2="21" y2="12")
        line(x1="8" y1="18" x2="21" y2="18")
        line(x1="3" y1="6" x2="3.01" y2="6")
        line(x1="3" y1="12" x2="3.01" y2="12")
        line(x1="3" y1="18" x2="3.01" y2="18")
      | Recomendaciones

    #recommendations-wrap
      if report.recommendations.length === 0
        p.no-findings ✅ Sin recomendaciones pendientes.
      else
        .scrollable
          ul.rec-list
            each rec in report.recommendations
              li= rec

  script.
    (function() {
      var events = JSON.parse(localStorage.getItem('iso_events') || '[]');
      if (!events.length) return;

      // ---- ISO Mapping — generado desde el servidor (isoMappingService.js) ----
      var ISO_MAPPINGS = !{isoMappingsJson};
      var BC           = !{isoBcJson};
      var IS           = !{isoIsJson};
      var RECS         = !{isoRecsJson};
      var ALL_STD      = !{isoAllStdJson};
      var ALIAS_MAP    = !{isoAliasMapJson};

      function clauseStatus(sev, etype) {
        if((sev==='CRITICAL'||sev==='HIGH')&&(etype==='ALARM'||etype==='ERROR')) return 'NON_COMPLIANT';
        if(sev==='MEDIUM'&&etype==='WARNING') return 'WARNING';
        return 'COMPLIANT';
      }
      function overallStatus(arr) {
        if(arr.indexOf('NON_COMPLIANT')>=0) return 'NON_COMPLIANT';
        if(arr.indexOf('WARNING')>=0) return 'WARNING';
        return 'COMPLIANT';
      }
      function resolveKey(mid) {
        return ALIAS_MAP[mid] || mid;
      }
      function mapEvent(ev) {
        var key = resolveKey(ev.module_id);
        var base = (ISO_MAPPINGS[key]||ISO_MAPPINGS[ev.module_id]||[]).map(function(c){ return Object.assign({},c,{status:clauseStatus(ev.severity,ev.event_type)}); });
        if(ev.severity==='CRITICAL') base.push(Object.assign({},BC,{status:'NON_COMPLIANT'}));
        if(ev.event_type==='ERROR')  base.push(Object.assign({},IS,{status:clauseStatus(ev.severity,ev.event_type)}));
        var cs = overallStatus(base.map(function(s){ return s.status; }));
        var recsEntry = RECS[key] || RECS[ev.module_id];
        var rec = cs==='COMPLIANT'
          ? 'El módulo "'+ev.module_id+'" opera dentro de los parámetros normativos. Continuar con el monitoreo regular.'
          : ((recsEntry&&recsEntry[cs])||('Revisar el módulo "'+ev.module_id+'" y tomar acción correctiva según '+ev.severity+'.'));
        return {isoStandards:base, complianceStatus:cs, recommendation:rec};
      }

      // ---- Generate report ----
      var ts = events.map(function(e){ return new Date(e.timestamp).getTime(); });
      var period = {from: new Date(Math.min.apply(null,ts)).toISOString(), to: new Date(Math.max.apply(null,ts)).toISOString()};
      var summary = {total:events.length,compliant:0,nonCompliant:0,warnings:0};
      var byStd = {};
      ALL_STD.forEach(function(s){
        byStd[s.key] = {compliant:0,nonCompliant:0,warnings:0,
          clauses:s.clauses.map(function(c){ return {clause:c.clause,title:c.title,compliant:0,nonCompliant:0,warnings:0}; })};
      });
      var criticals = [];
      var recSet = [];
      events.forEach(function(ev) {
        var m = mapEvent(ev);
        if(m.complianceStatus==='COMPLIANT')     summary.compliant++;
        else if(m.complianceStatus==='WARNING')  summary.warnings++;
        else                                     summary.nonCompliant++;
        if(ev.severity==='CRITICAL'&&m.complianceStatus==='NON_COMPLIANT')
          criticals.push({timestamp:ev.timestamp,module:ev.module_id,asset:ev.asset_id,
            standards:m.isoStandards.map(function(s){ return s.standard+' §'+s.clause; }).join(', '),recommendation:m.recommendation});
        if(m.recommendation&&recSet.indexOf(m.recommendation)<0) recSet.push(m.recommendation);
        m.isoStandards.forEach(function(iso){
          if(!byStd[iso.standard]) byStd[iso.standard]={compliant:0,nonCompliant:0,warnings:0,clauses:[]};
          var s = byStd[iso.standard];
          if(iso.status==='COMPLIANT')     s.compliant++;
          else if(iso.status==='WARNING')  s.warnings++;
          else                             s.nonCompliant++;
          var ce = s.clauses.filter(function(c){ return c.clause===iso.clause; })[0];
          if(!ce){ ce={clause:iso.clause,title:iso.title,compliant:0,nonCompliant:0,warnings:0}; s.clauses.push(ce); }
          if(iso.status==='COMPLIANT')     ce.compliant++;
          else if(iso.status==='WARNING')  ce.warnings++;
          else                             ce.nonCompliant++;
        });
      });

      // ---- Update DOM ----
      function $(id){ return document.getElementById(id); }
      $('stat-total').textContent       = summary.total;
      $('stat-compliant').textContent   = summary.compliant;
      $('stat-warnings').textContent    = summary.warnings;
      $('stat-noncompliant').textContent= summary.nonCompliant;

      var pEl = $('audit-period');
      if(pEl) pEl.textContent = ' \u00a0|\u00a0 Período: '+new Date(period.from).toLocaleDateString('es-MX')+' – '+new Date(period.to).toLocaleDateString('es-MX');

      // by-standard
      var bsWrap = $('by-standard-wrap');
      if(bsWrap) {
        var h='<div class="scrollable" style="max-height:500px">';
        Object.keys(byStd).forEach(function(name){
          var d=byStd[name];
          h+='<div class="standard-block"><div class="standard-header"><span class="standard-name">'+name+'</span>';
          h+='<div class="badges"><span class="badge badge-ok">✓ '+d.compliant+'</span><span class="badge badge-warn">⚠ '+d.warnings+'</span><span class="badge badge-fail">✗ '+d.nonCompliant+'</span></div></div>';
          h+='<table><thead><tr><th>Cláusula</th><th>Título</th><th>Conformes</th><th>Advertencias</th><th>No Conformes</th></tr></thead><tbody>';
          d.clauses.forEach(function(c){
            h+='<tr><td>'+c.clause+'</td><td>'+c.title+'</td><td class="status-COMPLIANT">'+c.compliant+'</td><td class="status-WARNING">'+c.warnings+'</td><td class="status-NON_COMPLIANT">'+c.nonCompliant+'</td></tr>';
          });
          h+='</tbody></table></div>';
        });
        h+='</div>';
        bsWrap.innerHTML=h;
      }

      // critical findings
      var cfWrap = $('critical-findings-wrap');
      if(cfWrap) {
        if(!criticals.length) {
          cfWrap.innerHTML='<p class="no-findings">✅ No se encontraron hallazgos críticos en el período analizado.</p>';
        } else {
          var h2='<div class="scrollable">';
          criticals.forEach(function(f){
            h2+='<div class="critical-block"><h4>🚨 '+f.module.toUpperCase()+' — '+f.asset+'</h4>';
            h2+='<p><strong>Timestamp:</strong> '+new Date(f.timestamp).toLocaleString('es-MX')+'</p>';
            h2+='<p><strong>Normas afectadas:</strong> '+f.standards+'</p>';
            h2+='<p><strong>Recomendación:</strong> '+f.recommendation+'</p></div>';
          });
          h2+='</div>';
          cfWrap.innerHTML=h2;
        }
      }

      // recommendations
      var recWrap = $('recommendations-wrap');
      if(recWrap) {
        if(!recSet.length) {
          recWrap.innerHTML='<p class="no-findings">✅ Sin recomendaciones pendientes.</p>';
        } else {
          var h3='<div class="scrollable"><ul class="rec-list">';
          recSet.forEach(function(r){ h3+='<li>'+r+'</li>'; });
          h3+='</ul></div>';
          recWrap.innerHTML=h3;
        }
      }
    })();
