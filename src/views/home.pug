extends layout

block content
  - pageTitle = 'Inicio'
  - currentPage = 'home'

  main

    //- ── HERO ──────────────────────────────────────────────────────
    section.ep-hero
      .ep-hero-inner
        .ep-hero-badge
          svg(width="10" height="10" viewBox="0 0 24 24" fill="currentColor")
            circle(cx="12" cy="12" r="10")
          | 2026 · CTRLHACK 2.0

        h1.ep-hero-title Expo Programador

        .ep-hero-meta
          span.ep-hero-meta-item
            svg(width="14" height="14" viewBox="0 0 448 512" fill="currentColor")
              path(d="M12 192h424c6.6 0 12 5.4 12 12v260c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V204c0-6.6 5.4-12 12-12zm436-44v-36c0-26.5-21.5-48-48-48h-48V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H160V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H48C21.5 64 0 85.5 0 112v36c0 6.6 5.4 12 12 12h424c6.6 0 12-5.4 12-12z")
            span(data-es="16 de Mayo, 2026" data-en="May 16, 2026") 16 de Mayo, 2026
          span.ep-hero-meta-sep /
          span.ep-hero-meta-item
            svg(width="14" height="14" viewBox="0 0 384 512" fill="currentColor")
              path(d="M172.268 501.67C26.97 291.031 0 269.413 0 192 0 85.961 85.961 0 192 0s192 85.961 192 192c0 77.413-26.97 99.031-172.268 309.67-9.535 13.774-29.93 13.773-39.464 0z")
            | Ciudad Juárez, Chihuahua

        .ep-hero-cta
          a.btn.btn-primary.btn-lg(href="https://www.eventbrite.com/e/ctrlhack-20-tickets-1980653539053" target="_blank")
            svg(width="16" height="16" viewBox="0 0 576 512" fill="currentColor")
              path(d="M576 240v32c0 8.8-7.2 16-16 16h-16c0 44.2-35.8 80-80 80s-80-35.8-80-80H192c0 44.2-35.8 80-80 80s-80-35.8-80-80H16c-8.8 0-16-7.2-16-16V240c0-8.8 7.2-16 16-16h16V112c0-26.5 21.5-48 48-48h352c26.5 0 48 21.5 48 48v112h16c8.8 0 16 7.2 16 16z")
            span(data-es="Boletos" data-en="Tickets") Boletos
          a.btn.btn-outline.btn-lg(href="#hackaton")
            svg(width="16" height="16" viewBox="0 0 640 512" fill="currentColor")
              path(d="M255.03 261.65c6.25 6.25 16.38 6.25 22.63 0l11.31-11.31c6.25-6.25 6.25-16.38 0-22.63L253.25 192l35.72-35.72c6.25-6.25 6.25-16.38 0-22.63l-11.31-11.31c-6.25-6.25-16.38-6.25-22.63 0l-58.34 58.34c-6.25 6.25-6.25 16.38 0 22.63l58.34 58.34zm96.01-11.3l11.31 11.31c6.25 6.25 16.38 6.25 22.63 0l58.34-58.34c6.25-6.25 6.25-16.38 0-22.63l-58.34-58.34c-6.25-6.25-16.38-6.25-22.63 0l-11.31 11.31c-6.25 6.25-6.25 16.38 0 22.63L386.75 192l-35.71 35.72c-6.25 6.25-6.25 16.37 0 22.63zM624 416H381.54c-.74 19.81-14.71 32-32.74 32H288c-18.69 0-33.02-17.47-32.77-32H16c-8.8 0-16 7.2-16 16v16c0 35.2 28.8 64 64 64h512c35.2 0 64-28.8 64-64v-16c0-8.8-7.2-16-16-16zM576 48c0-26.4-21.6-48-48-48H112C85.6 0 64 21.6 64 48v336h512V48zm-64 272H128V64h384v256z")
            span(data-es="CTRL+HACK 2.0 BASES" data-en="CTRL+HACK 2.0 RULES") CTRL+HACK 2.0 BASES

        //- Countdown
        .ep-countdown-wrap
          p.ep-countdown-label(data-es="FALTAN" data-en="TIME LEFT") FALTAN
          #ep-countdown.ep-countdown
            .ep-countdown-item
              span#cd-days.ep-countdown-num --
              span.ep-countdown-unit(data-es="Días" data-en="Days") Días
            .ep-countdown-sep :
            .ep-countdown-item
              span#cd-hours.ep-countdown-num --
              span.ep-countdown-unit(data-es="Horas" data-en="Hours") Horas
            .ep-countdown-sep :
            .ep-countdown-item
              span#cd-mins.ep-countdown-num --
              span.ep-countdown-unit(data-es="Minutos" data-en="Minutes") Minutos
            .ep-countdown-sep :
            .ep-countdown-item
              span#cd-secs.ep-countdown-num --
              span.ep-countdown-unit(data-es="Segundos" data-en="Seconds") Segundos
          p.ep-countdown-venue
            svg(width="14" height="14" viewBox="0 0 384 512" fill="currentColor" style="margin-right:.4rem;vertical-align:middle")
              path(d="M172.268 501.67C26.97 291.031 0 269.413 0 192 0 85.961 85.961 0 192 0s192 85.961 192 192c0 77.413-26.97 99.031-172.268 309.67-9.535 13.774-29.93 13.773-39.464 0z")
            | La Rodadora Espacio Interactivo, Cd. Juárez

    //- ── TICKER ─────────────────────────────────────────────────────
    .ep-ticker-wrap
      .ep-ticker
        span(data-es="Conectando talento e industria" data-en="Connecting talent and industry") Conectando talento e industria
        span.sep /
        span Agent as a Service
        span.sep /
        span(data-es="13 agentes · 125 herramientas" data-en="13 agents · 125 tools") 13 agentes · 125 herramientas
        span.sep /
        span(data-es="Cloud + Edge + Hybrid" data-en="Cloud + Edge + Hybrid") Cloud + Edge + Hybrid
        span.sep /
        span(data-es="Industria 4.0 en tiempo real" data-en="Industry 4.0 in real time") Industria 4.0 en tiempo real
        span.sep /
        span(data-es="Agentes que aprenden tu operación" data-en="Agents that learn your operation") Agentes que aprenden tu operación
        span.sep /
        span Hackatón CTRL+HACK 2.0
        span.sep /
        span(data-es="No software — inteligencia industrial" data-en="Not software — industrial intelligence") No software — inteligencia industrial
        span.sep /
        //- duplicate for infinite loop
        span(data-es="Conectando talento e industria" data-en="Connecting talent and industry") Conectando talento e industria
        span.sep /
        span Agent as a Service
        span.sep /
        span(data-es="13 agentes · 125 herramientas" data-en="13 agents · 125 tools") 13 agentes · 125 herramientas
        span.sep /
        span(data-es="Cloud + Edge + Hybrid" data-en="Cloud + Edge + Hybrid") Cloud + Edge + Hybrid
        span.sep /
        span(data-es="Industria 4.0 en tiempo real" data-en="Industry 4.0 in real time") Industria 4.0 en tiempo real
        span.sep /
        span(data-es="Agentes que aprenden tu operación" data-en="Agents that learn your operation") Agentes que aprenden tu operación
        span.sep /

    //- ── ASÍ SE VIVIÓ 2025 (SOBRE EL EVENTO) ───────────────────────
    section.ep-section#sobre
      .ep-section-inner
        .ep-section-head
          p.ep-section-badge(data-es="POR QUÉ ASISTIR" data-en="WHY ATTEND") POR QUÉ ASISTIR
          h2.ep-section-title(data-es="Así se vivió Expo Programador 2025" data-en="How Expo Programador 2025 Was") Así se vivió Expo Programador 2025
          p.ep-section-subdesc(data-es="Un encuentro para crear y conectar" data-en="A gathering to create and connect") Un encuentro para crear y conectar
        .ep-about-layout
          .ep-about-text
            p.ep-about-desc
              span(data-es="Expo Programador 2025 fue un espacio abierto donde talento, industria y tecnología se unieron para impulsar la innovación, el desarrollo de soluciones y el crecimiento del ecosistema local." data-en="Expo Programador 2025 was an open space where talent, industry and technology came together to drive innovation, develop solutions and grow the local tech ecosystem.") Expo Programador 2025 fue un espacio abierto donde talento, industria y tecnología se unieron para impulsar la innovación, el desarrollo de soluciones y el crecimiento del ecosistema local.
            ul.ep-check-list
              li
                svg(width="16" height="16" viewBox="0 0 512 512" fill="currentColor")
                  path(d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z")
                span(data-es="Networking, conferencias y colaboración" data-en="Networking, talks and collaboration") Networking, conferencias y colaboración
              li
                svg(width="16" height="16" viewBox="0 0 512 512" fill="currentColor")
                  path(d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z")
                span(data-es="Hackatón CTRL+HACK" data-en="CTRL+HACK Hackathon") Hackatón CTRL+HACK
              li
                svg(width="16" height="16" viewBox="0 0 512 512" fill="currentColor")
                  path(d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z")
                span(data-es="Tendencias en tecnología aplicada a la industria" data-en="Industry-applied technology trends") Tendencias en tecnología aplicada a la industria
          .ep-about-img
            img(src="/public/img/c1.webp" alt="Expo Programador 2025" loading="lazy")

        //- Galería 2025
        .ep-gallery-tabs
          button.ep-tab.active(data-tab="ponencias" data-es="Ponencias" data-en="Talks") Ponencias
          button.ep-tab(data-tab="presidium") Presidium
          button.ep-tab(data-tab="hackaton") Hackaton CTRL+HACK

        //- Carousel Ponencias
        .ep-carousel-section(id="tab-ponencias")
          .ep-carousel-wrap
            .ep-carousel-track#carousel-ponencias
              .ep-carousel-item
                img(src="/public/img/ev1.jpg" alt="Ponencias 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/ev2.jpg" alt="Ponencias 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/ev3.jpg" alt="Ponencias 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/ev4.jpg" alt="Ponencias 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/ev5.jpg" alt="Ponencias 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/ev6.jpg" alt="Ponencias 2025" loading="lazy")
            button.ep-carousel-btn.ep-carousel-btn-prev(onclick="carouselPrev('ponencias')") &#8249;
            button.ep-carousel-btn.ep-carousel-btn-next(onclick="carouselNext('ponencias')") &#8250;

        //- Carousel Presidium
        .ep-carousel-section.hidden(id="tab-presidium")
          .ep-carousel-wrap
            .ep-carousel-track#carousel-presidium
              .ep-carousel-item
                img(src="/public/img/pon1.jpg" alt="Presidium 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/pon2.jpg" alt="Presidium 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/pon3.png" alt="Presidium 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/pon4.png" alt="Presidium 2025" loading="lazy")
            button.ep-carousel-btn.ep-carousel-btn-prev(onclick="carouselPrev('presidium')") &#8249;
            button.ep-carousel-btn.ep-carousel-btn-next(onclick="carouselNext('presidium')") &#8250;

        //- Carousel Hackaton CTRL+HACK
        .ep-carousel-section.hidden(id="tab-hackaton")
          .ep-carousel-wrap
            .ep-carousel-track#carousel-hackaton
              .ep-carousel-item
                img(src="/public/img/pres1.jpg" alt="Hackaton CTRL+HACK 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/pres2.jpg" alt="Hackaton CTRL+HACK 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/pres3.jpg" alt="Hackaton CTRL+HACK 2025" loading="lazy")
              .ep-carousel-item
                img(src="/public/img/pres4.png" alt="Hackaton CTRL+HACK 2025" loading="lazy")
            button.ep-carousel-btn.ep-carousel-btn-prev(onclick="carouselPrev('hackaton')") &#8249;
            button.ep-carousel-btn.ep-carousel-btn-next(onclick="carouselNext('hackaton')") &#8250;

    //- ── AGENT AS A SERVICE ─────────────────────────────────────────
    section.ep-section.ep-section-alt#plataforma
      .ep-section-inner
        .ep-section-head
          p.ep-section-badge(data-es="AGENT AS A SERVICE" data-en="AGENT AS A SERVICE") AGENT AS A SERVICE
          h2.ep-section-title(data-es="Agentes industriales que trabajan por ti" data-en="Industrial agents that work for you") Agentes industriales que trabajan por ti
          p.ep-section-subdesc(data-es="No vendemos software — desplegamos agentes especializados que aprenden tu operación, detectan anomalías y toman acción. 13 agentes, 125 herramientas industriales." data-en="We don't sell software — we deploy specialized agents that learn your operation, detect anomalies and take action. 7 agents, 63 industrial tools.") No vendemos software — desplegamos agentes especializados que aprenden tu operación, detectan anomalías y toman acción. 13 agentes, 125 herramientas industriales.

        .ep-section-divider
          p.ep-section-note(data-es="También incluimos:" data-en="Also included:") También incluimos:

        .ep-features-grid
          a.ep-feat(href="/integracion-iso")
            .ep-feat-icon.ep-feat-icon-green
              svg(width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#34D399" stroke-width="2")
                path(d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z")
                polyline(points="14,2 14,8 20,8")
                line(x1="9" y1="13" x2="15" y2="13")
            .ep-feat-title(data-es="Simulador Auditoría ISO" data-en="ISO Audit Simulator") Simulador Auditoría ISO
            p.ep-feat-desc(data-es="Simulación industrial, auditoría ISO y dashboard de métricas en tiempo real." data-en="Industrial simulation, ISO audit and real-time metrics dashboard.") Simulación industrial, auditoría ISO y dashboard de métricas en tiempo real.
            span.ep-feat-link
              span(data-es="Ver reporte" data-en="View report") Ver reporte
              svg(width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                line(x1="5" y1="12" x2="19" y2="12")
                polyline(points="12,5 19,12 12,19")
          a.ep-feat(href="/agentes" target="_blank")
            .ep-feat-icon.ep-feat-icon-orange
              svg(width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FF5722" stroke-width="2")
                circle(cx="12" cy="12" r="10")
                path(d="M12 8v4l3 3")
                path(d="M9 3.5A9 9 0 0 1 21 12")
            .ep-feat-title(data-es="Explorar Agentes" data-en="Explore Agents") Explorar Agentes
            p.ep-feat-desc(data-es="13 agentes industriales, 125 herramientas especializadas. Explora cada uno en detalle." data-en="13 industrial agents, 125 specialized tools. Explore each one in detail.") 13 agentes industriales, 125 herramientas especializadas. Explora cada uno en detalle.
            span.ep-feat-link
              span(data-es="Ver agentes" data-en="View agents") Ver agentes
              svg(width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                line(x1="5" y1="12" x2="19" y2="12")
                polyline(points="12,5 19,12 12,19")

    //- ── HACKATON CTRL+HACK 2.0 ─────────────────────────────────────
    section.ep-section#hackaton
      .ep-section-inner
        .ep-section-head
          p.ep-section-badge HACKATON
          h2.ep-section-title CTRL + HACK 2.0
          p.ep-section-subdesc(data-es="Conecta con el ecosistema tecnológico y descubre cómo ser parte de un evento que transforma ideas en soluciones." data-en="Connect with the tech ecosystem and discover how to be part of an event that transforms ideas into solutions.") Conecta con el ecosistema tecnológico y descubre cómo ser parte de un evento que transforma ideas en soluciones.

        .ep-hack-layout
          .ep-hack-img-col
            img.ep-hack-bases-img(src="/public/img/hack-bases.jpg" alt="Bases del concurso CTRL+HACK 2.0" loading="lazy")
          .ep-hack-cta-col
            .ep-hack-docs
              a.ep-hack-doc-btn(href="/public/docs/BASES-CTRLHACK-2.0.pdf" target="_blank")
                svg(width="15" height="15" viewBox="0 0 384 512" fill="currentColor")
                  path(d="M369.9 97.9L286 14C277 5 264.8-.1 252.1-.1H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h288c26.5 0 48-21.5 48-48V131.9c0-12.7-5.1-25-14.1-34zM332.1 128H256V51.9l76.1 76.1zM48 464V48h160v104c0 13.3 10.7 24 24 24h104v288H48z")
                span(data-es="Bases Oficiales" data-en="Official Rules") Bases Oficiales
              a.ep-hack-doc-btn(href="/public/docs/RUBRICA-EVALUACION.pdf" target="_blank")
                svg(width="15" height="15" viewBox="0 0 384 512" fill="currentColor")
                  path(d="M369.9 97.9L286 14C277 5 264.8-.1 252.1-.1H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h288c26.5 0 48-21.5 48-48V131.9c0-12.7-5.1-25-14.1-34zM332.1 128H256V51.9l76.1 76.1zM48 464V48h160v104c0 13.3 10.7 24 24 24h104v288H48z")
                span(data-es="Rúbrica de Evaluación" data-en="Scoring Rubric") Rúbrica de Evaluación
              a.ep-hack-doc-btn(href="/public/docs/INDUSTRIAL-EVENT-STANDARD.pdf" target="_blank")
                svg(width="15" height="15" viewBox="0 0 384 512" fill="currentColor")
                  path(d="M369.9 97.9L286 14C277 5 264.8-.1 252.1-.1H48C21.5 0 0 21.5 0 48v416c0 26.5 21.5 48 48 48h288c26.5 0 48-21.5 48-48V131.9c0-12.7-5.1-25-14.1-34zM332.1 128H256V51.9l76.1 76.1zM48 464V48h160v104c0 13.3 10.7 24 24 24h104v288H48z")
                span(data-es="Estándar de Eventos" data-en="Event Standard") Estándar de Eventos
          .ep-hack-prizes-col
            p.ep-hack-col-label(data-es="Premios" data-en="Prizes") Premios
            .ep-prizes
              .ep-prize.ep-prize-1
                .ep-prize-place 1°
                .ep-prize-amount $15,000
                .ep-prize-label(data-es="MXN — Primer lugar" data-en="MXN — 1st place") MXN — Primer lugar
              .ep-prize.ep-prize-2
                .ep-prize-place 2°
                .ep-prize-amount $10,000
                .ep-prize-label(data-es="MXN — Segundo lugar" data-en="MXN — 2nd place") MXN — Segundo lugar
              .ep-prize.ep-prize-3
                .ep-prize-place 3°
                .ep-prize-amount $5,000
                .ep-prize-label(data-es="MXN — Tercer lugar" data-en="MXN — 3rd place") MXN — Tercer lugar

    //- ── LOGOS / PATROCINADORES ─────────────────────────────────────
    section.ep-logos-section
      .ep-logos-inner
        p.ep-logos-label(data-es="Empresas e instituciones participantes" data-en="Participating companies and institutions") Empresas e instituciones participantes
        .ep-logos-grid
          .ep-logo-item: img(src="/public/img/logo-itcj.png"       alt="ITCJ"            loading="lazy")
          .ep-logo-item: img(src="/public/img/logo-escudo.png"     alt="Escudo amarillo" loading="lazy")
          .ep-logo-item.ep-logo-item--light: img(src="/public/img/logo-historias.png"  alt="Historias"       loading="lazy")
          .ep-logo-item: img(src="/public/img/logo-wp1.png"        alt="Patrocinador"    loading="lazy")
          .ep-logo-item: img(src="/public/img/logo-wp2.png"        alt="Patrocinador"    loading="lazy")
          .ep-logo-item: img(src="/public/img/logo-canacintra.png" alt="CANACINTRA"      loading="lazy")
          .ep-logo-item: img(src="/public/img/logo-223231.png"     alt="Patrocinador"    loading="lazy")
          .ep-logo-item: img(src="/public/img/logo-binmatter.png"  alt="Binmatter"       loading="lazy")
          .ep-logo-item: img(src="/public/img/logo-centro.png"     alt="Centro entrenamiento" loading="lazy")

    //- ── TICKETS ────────────────────────────────────────────────────
    section.ep-section.ep-section-alt#tickets
      .ep-section-inner
        .ep-section-head
          p.ep-section-badge(data-es="OPCIONES DE ACCESO" data-en="ACCESS OPTIONS") OPCIONES DE ACCESO
          h2.ep-section-title(data-es="Elige tu boleto" data-en="Choose your ticket") Elige tu boleto
          p.ep-section-subdesc(data-es="Selecciona el acceso que mejor se adapte a tu perfil y forma parte del evento que conecta talento, industria y tecnología." data-en="Select the access that best fits your profile and be part of the event that connects talent, industry and technology.") Selecciona el acceso que mejor se adapte a tu perfil y forma parte del evento que conecta talento, industria y tecnología.
        .ep-tickets-grid
          .ep-ticket
            h3.ep-ticket-name CTRL HACK Individual
            .ep-ticket-price
              span.ep-ticket-amount $330
              span.ep-ticket-currency MXN
            h4.ep-ticket-inc(data-es="Incluye:" data-en="Includes:") Incluye:
            ul.ep-ticket-list
              li(data-es="Kit de bienvenida y certificación" data-en="Welcome kit and certification") Kit de bienvenida y certificación
              li(data-es="Networking con empresas y mentores" data-en="Networking with companies and mentors") Networking con empresas y mentores
              li(data-es="Materiales digitales y grabaciones" data-en="Digital materials and recordings") Materiales digitales y grabaciones
            a.btn.btn-outline(href="https://www.eventbrite.com/e/ctrlhack-20-tickets-1980653539053" target="_blank" data-es="Comprar Boleto" data-en="Buy Ticket") Comprar Boleto
          .ep-ticket.ep-ticket-featured
            .ep-ticket-badge(data-es="RECOMENDADO" data-en="RECOMMENDED") RECOMENDADO
            h3.ep-ticket-name Ctrl Hack Equipo
            .ep-ticket-price
              span.ep-ticket-amount $990
              span.ep-ticket-currency MXN
