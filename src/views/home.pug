    }
    .ep-hero-meta-item { display: flex; align-items: center; gap: .4rem; font-size: .9rem; color: var(--text-2); font-weight: 500; }
    .ep-hero-meta-sep  { color: var(--text-3); }
    .ep-hero-cta       { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 3rem; }

    /* Countdown */
    .ep-countdown-wrap { text-align: center; display: flex; flex-direction: column; align-items: center; }
    .ep-countdown-label { font-size: .7rem; font-weight: 700; letter-spacing: 2px; color: #A78BFA; text-transform: uppercase; margin-bottom: .75rem; }
    .ep-countdown {
      display: inline-flex; align-items: center; gap: .35rem;
      background: linear-gradient(135deg, rgba(12,22,48,.9), rgba(8,15,34,.95));
      border: 1px solid rgba(139,92,246,.4);
      border-radius: var(--radius-lg); padding: .6rem 1rem; margin-bottom: .75rem;
      box-shadow: 0 0 40px rgba(139,92,246,.2), inset 0 1px 0 rgba(255,255,255,.06);
    }
    .ep-countdown-item { display: flex; flex-direction: column; align-items: center; min-width: 44px; }
    .ep-countdown-num {
      font-size: 1.6rem; font-weight: 900; letter-spacing: -1px; line-height: 1;
      background: linear-gradient(135deg, #FFFFFF, #C4B5FD, #60A5FA);
