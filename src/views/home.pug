    }

  script.
    // ── Countdown to May 16, 2026 ──────────────────────────────────
    (function(){
      var target = new Date('2026-05-16T08:00:00-06:00').getTime();
      function tick(){
        var diff = Math.max(0, target - Date.now());
        var d = Math.floor(diff/86400000);
        var h = Math.floor((diff%86400000)/3600000);
        var m = Math.floor((diff%3600000)/60000);
        var s = Math.floor((diff%60000)/1000);
        document.getElementById('cd-days').textContent  = String(d).padStart(2,'0');
        document.getElementById('cd-hours').textContent = String(h).padStart(2,'0');
        document.getElementById('cd-mins').textContent  = String(m).padStart(2,'0');
        document.getElementById('cd-secs').textContent  = String(s).padStart(2,'0');
      }
      tick(); setInterval(tick, 1000);
    })();

    // ── Gallery tabs ───────────────────────────────────────────────
    document.querySelectorAll('.ep-tab').forEach(function(btn){
      btn.addEventListener('click', function(){
        var tab = this.dataset.tab;
        document.querySelectorAll('.ep-tab').forEach(function(b){ b.classList.remove('active'); });
        this.classList.add('active');
        ['ponencias','presidium','hackaton'].forEach(function(t){
          var el = document.getElementById('tab-' + t);
          if(el) el.classList.toggle('hidden', t !== tab);
        });
      });
    });

    // ── Carousel ────────────────────────────────────────────────────
    var carouselPos = {};
    function carouselItems(id) {
      return document.querySelectorAll('#carousel-' + id + ' .ep-carousel-item');
    }
    function carouselMove(id, dir) {
      var items = carouselItems(id);
      var total = items.length;
      if (!carouselPos[id]) carouselPos[id] = 0;
      var visible = 3;
      var max = Math.max(0, total - visible);
      carouselPos[id] = Math.min(max, Math.max(0, carouselPos[id] + dir));
      var itemW = items[0] ? items[0].offsetWidth + 9.6 : 0;
      document.getElementById('carousel-' + id).style.transform = 'translateX(-' + (carouselPos[id] * itemW) + 'px)';
    }
    function carouselPrev(id) { carouselMove(id, -1); }
    function carouselNext(id) { carouselMove(id, 1); }

    // ── Newsletter form ────────────────────────────────────────────
    function epNlSubmit(e){
      e.preventDefault();
      var msg = document.getElementById('ep-nl-msg');
      msg.className = 'ep-nl-msg ok';
      msg.textContent = _epLang === 'en'
        ? 'Thank you! We will keep you updated on all Expo Programador 2026 news.'
        : '¡Gracias! Te avisaremos con todas las novedades de Expo Programador 2026.';
      msg.style.display = 'block';
      document.getElementById('ep-nl-email').value = '';
      return false;
