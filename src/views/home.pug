    .ep-countdown-venue { font-size: .82rem; color: var(--text-3); }

    /* Ticker */
    .ep-ticker-wrap {
      overflow: hidden;
      background: linear-gradient(90deg, rgba(139,92,246,.12), rgba(6,182,212,.08), rgba(139,92,246,.12));
