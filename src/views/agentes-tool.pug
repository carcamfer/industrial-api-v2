extends layout

block content
  .page-header
    .page-header-inner
      div
        .page-breadcrumb
          a(href="/") Inicio
          svg(width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
            polyline(points="9,18 15,12 9,6")
          a(href="/agentes")
            span(data-es="Agentes" data-en="Agents") Agentes
          svg(width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
            polyline(points="9,18 15,12 9,6")
          span(data-es="Tools" data-en="Tools") Tools
          svg(width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
            polyline(points="9,18 15,12 9,6")
          code= tool.id
        h1.page-title
          span.tool-title-friendly
            span(data-es=tool.nameEs data-en=tool.name)= tool.nameEs
        .page-subtitle
          span.badge(class='badge-' + tool.type.toLowerCase())= tool.type
          | &nbsp;·&nbsp;
          span.text-muted= tool.category
          | &nbsp;·&nbsp;
          code.tool-id-inline= tool.id
      .page-actions
        a.btn.btn-outline(href="javascript:history.back()")
          span(data-es="← Volver" data-en="← Back") ← Volver

  main

    section.agent-section
      h2.section-title
        svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
          circle(cx="12" cy="12" r="10")
          line(x1="12" y1="8" x2="12" y2="12")
          line(x1="12" y1="16" x2="12.01" y2="16")
        span(data-es="Descripción" data-en="Description") Descripción
      .card
        p
          span(data-es=tool.descriptionEs data-en=tool.descriptionEn)= tool.descriptionEs

    - const inputProps  = (tool.inputSchema  && tool.inputSchema.properties)  ? Object.entries(tool.inputSchema.properties)  : []
    - const outputProps = (tool.outputSchema && tool.outputSchema.properties) ? Object.entries(tool.outputSchema.properties) : []
    - const inputRequired = (tool.inputSchema && tool.inputSchema.required) ? tool.inputSchema.required : []

    section.agent-section
      h2.section-title
        svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
          polyline(points="16,18 22,12 16,6")
          polyline(points="8,6 2,12 8,18")
        span(data-es="Parámetros de la Tool" data-en="Tool Parameters") Parámetros de la Tool
      .schema-split
        .schema-half
          .schema-table-header
            svg(width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
              line(x1="12" y1="5" x2="12" y2="19")
              polyline(points="19,12 12,19 5,12")
            span(data-es="Entrada — lo que recibe" data-en="Input — what it receives") Entrada — lo que recibe
          if inputProps.length > 0
            table.schema-params-table
              thead
                tr
                  th(data-es="Parámetro" data-en="Parameter") Parámetro
                  th(data-es="Tipo" data-en="Type") Tipo
                  th(data-es="Req." data-en="Req.") Req.
                  th(data-es="Default" data-en="Default") Default
              tbody
                each pair in inputProps
                  - var propName = pair[0]; var prop = pair[1]
                  tr
                    td
                      code.param-name= propName
                    td
                      span(class='type-pill type-' + (prop.type || 'any'))= prop.type || 'any'
                    td.req-cell
                      if inputRequired.includes(propName)
                        span.req-yes(data-es="✓ Sí" data-en="✓ Yes") ✓ Sí
                      else
                        span.req-no —
                    td.default-cell
                      if prop.default !== undefined
                        code.default-val= String(prop.default)
                      else
                        span.req-no —
          else
            p.schema-empty(data-es="Sin parámetros de entrada" data-en="No input parameters") Sin parámetros de entrada

        .schema-half
          .schema-table-header
            svg(width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
              line(x1="12" y1="19" x2="12" y2="5")
              polyline(points="5,12 12,5 19,12")
            span(data-es="Salida — lo que devuelve" data-en="Output — what it returns") Salida — lo que devuelve
          if outputProps.length > 0
            table.schema-params-table
              thead
                tr
                  th(data-es="Campo" data-en="Field") Campo
                  th(data-es="Tipo" data-en="Type") Tipo
                  th(data-es="Formato" data-en="Format") Formato
              tbody
                each pair in outputProps
                  - var propName = pair[0]; var prop = pair[1]
                  tr
                    td
                      code.param-name= propName
                    td
                      span(class='type-pill type-' + (prop.type || 'any'))= prop.type || 'any'
                    td.default-cell
                      if prop.format
                        span.format-tag= prop.format
                      else if prop.items
                        span.format-tag items→
                          code= prop.items.type || 'obj'
                      else
                        span.req-no —
          else
            p.schema-empty(data-es="Sin campos de salida" data-en="No output fields") Sin campos de salida

    if tool.devSpec
      section.agent-section.dev-spec-section
        h2.section-title
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            path(d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z")
            polyline(points="14,2 14,8 20,8")
            line(x1="16" y1="13" x2="8" y2="13")
            line(x1="16" y1="17" x2="8" y2="17")
            polyline(points="10,9 9,9 8,9")
          span(data-es="Guía de Implementación" data-en="Implementation Guide") Guía de Implementación
        .dev-spec-grid
          .dev-spec-card.dev-spec-input
            .dev-spec-card-header
              span.dev-spec-icon
                svg(width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                  line(x1="12" y1="5" x2="12" y2="19")
                  polyline(points="19,12 12,19 5,12")
              span.dev-spec-label(data-es="¿Por qué estos parámetros de entrada?" data-en="Why these input parameters?") ¿Por qué estos parámetros de entrada?
            p.dev-spec-body= tool.devSpec.whyInput
          .dev-spec-card.dev-spec-calc
            .dev-spec-card-header
              span.dev-spec-icon
                svg(width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                  rect(x="4" y="2" width="16" height="20" rx="2" ry="2")
                  line(x1="8" y1="6" x2="16" y2="6")
                  line(x1="8" y1="10" x2="16" y2="10")
                  line(x1="8" y1="14" x2="12" y2="14")
              span.dev-spec-label(data-es="Cálculos y lógica a implementar" data-en="Calculations & logic to implement") Cálculos y lógica a implementar
            p.dev-spec-body= tool.devSpec.calculations
          .dev-spec-card.dev-spec-output
            .dev-spec-card-header
              span.dev-spec-icon
                svg(width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                  line(x1="12" y1="19" x2="12" y2="5")
                  polyline(points="5,12 12,5 19,12")
              span.dev-spec-label(data-es="¿Por qué estos parámetros de salida?" data-en="Why these output parameters?") ¿Por qué estos parámetros de salida?
            p.dev-spec-body= tool.devSpec.whyOutput
          .dev-spec-card.dev-spec-ui
            .dev-spec-card-header
              span.dev-spec-icon
                svg(width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                  rect(x="3" y="3" width="18" height="18" rx="2")
                  line(x1="3" y1="9" x2="21" y2="9")
                  line(x1="9" y1="21" x2="9" y2="9")
              span.dev-spec-label(data-es="Interfaz gráfica recomendada" data-en="Recommended UI") Interfaz gráfica recomendada
            p.dev-spec-body= tool.devSpec.uiSuggestion

    - const rulesFrom = commRules.filter(function(r){ return r.targetToolId === tool.id; })
    - const rulesTo   = commRules.filter(function(r){ return r.sourceToolId === tool.id; })

    if commRules.length > 0
      section.agent-section
        h2.section-title
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            circle(cx="18" cy="5" r="3")
            circle(cx="6" cy="12" r="3")
            circle(cx="18" cy="19" r="3")
            line(x1="8.59" y1="13.51" x2="15.42" y2="17.49")
            line(x1="15.41" y1="6.51" x2="8.59" y2="10.49")
          span(data-es="Conexiones con otras Tools" data-en="Connections with other Tools") Conexiones con otras Tools
        .conn-grid
          if rulesFrom.length > 0
            .conn-column
              .conn-column-label.conn-label-from
                svg(width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                  line(x1="19" y1="12" x2="5" y2="12")
                  polyline(points="12,5 5,12 12,19")
                span(data-es="Recibe de" data-en="Receives from") Recibe de
              each rule in rulesFrom
                .conn-card.conn-card-from
                  .conn-card-top
                    a.conn-tool-link(href='/agentes/tools/' + rule.sourceToolId)
                      code= rule.sourceToolId
                  .conn-card-meta
                    span.badge.badge-event= rule.event
                    span.proto-badge(class='proto-' + rule.protocol.toLowerCase().replace('/','-'))= rule.protocol
                  if rule.description
                    p.conn-desc= rule.description
          if rulesTo.length > 0
            .conn-column
              .conn-column-label.conn-label-to
                svg(width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                  line(x1="5" y1="12" x2="19" y2="12")
                  polyline(points="12,5 19,12 12,19")
                span(data-es="Envía a" data-en="Sends to") Envía a
              each rule in rulesTo
                .conn-card.conn-card-to
                  .conn-card-top
                    a.conn-tool-link(href='/agentes/tools/' + rule.targetToolId)
                      code= rule.targetToolId
                  .conn-card-meta
                    span.badge.badge-event= rule.event
                    span.proto-badge(class='proto-' + rule.protocol.toLowerCase().replace('/','-'))= rule.protocol
                  if rule.description
                    p.conn-desc= rule.description

    - const agentIsoAlarms = usedByAgents.reduce(function(acc, a) { return acc.concat(a.isoAlarms || []); }, []).filter(function(v,i,s){ return s.indexOf(v)===i; })

    if toolIsoAlarm
      section.agent-section
        h2.section-title
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            path(d="M22 11.08V12a10 10 0 11-5.93-9.14")
            polyline(points="22,4 12,14.01 9,11.01")
          span(data-es="Alarma ISO que genera esta tool" data-en="ISO Alarm generated by this tool") Alarma ISO que genera esta tool
        .iso-alarm-block
          .iso-alarm-intro
            span(data-es="Cuando esta tool detecta un evento relevante, emite la siguiente alarma al Simulador ISO. El campo " data-en="When this tool detects a relevant event, it emits the following alarm to the ISO Simulator. The field ") Cuando esta tool detecta un evento relevante, emite la siguiente alarma al Simulador ISO. El campo
            code standardEvent.module.id
            span(data-es=" debe usar este nombre exacto." data-en=" must use this exact name.") debe usar este nombre exacto.
          .iso-alarm-list
            .iso-alarm-item
              span.iso-alarm-dot ●
              code.iso-alarm-name= toolIsoAlarm
              span.iso-alarm-label(data-es=" → se visualiza en el Dashboard ISO y Reporte de Auditoría" data-en=" → visible in ISO Dashboard and Audit Report") → se visualiza en el Dashboard ISO y Reporte de Auditoría
          .iso-alarm-dev-note
            svg(width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
              circle(cx="12" cy="12" r="10")
              line(x1="12" y1="8" x2="12" y2="12")
              line(x1="12" y1="16" x2="12.01" y2="16")
            span(data-es="Al ejecutar el demo de esta tool, el evento se guardará en el Simulador ISO con este nombre de alarma." data-en="When running this tool's demo, the event will be saved to the ISO Simulator with this alarm name.") Al ejecutar el demo de esta tool, el evento se guardará en el Simulador ISO con este nombre de alarma.

    section.agent-section#tool-demo-section
      h2.section-title
        svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
          polygon(points="5,3 19,12 5,21 5,3")
        span(data-es="Demo en vivo" data-en="Live Demo") Demo en vivo
      .tool-demo-panel
        .tool-demo-header
          .tool-demo-status
            span.demo-dot#tool-demo-dot
            span#tool-demo-status-text(data-es="Listo" data-en="Ready") Listo
          .tool-demo-controls
            button.btn.btn-primary#btn-run-tool-demo
              svg(width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                polygon(points="5,3 19,12 5,21 5,3")
              span#btn-run-tool-demo-text(data-es="Ejecutar Demo" data-en="Run Demo") Ejecutar Demo
            button.btn.btn-ghost#btn-reset-tool-demo(style="display:none")
              span(data-es="Reiniciar" data-en="Reset") Reiniciar
        .tool-demo-body#tool-demo-body
          .tool-demo-idle#tool-demo-idle
            svg(width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.25")
              polygon(points="5,3 19,12 5,21 5,3")
            p(data-es="Presiona Ejecutar Demo para ver cómo actúa esta tool en tiempo real" data-en="Press Run Demo to see how this tool acts in real time") Presiona Ejecutar Demo para ver cómo actúa esta tool en tiempo real

    if usedByAgents.length > 0
      section.agent-section
        h2.section-title
          svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
            path(d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2")
            circle(cx="9" cy="7" r="4")
          span(data-es="Agentes que usan esta tool" data-en="Agents using this tool") Agentes que usan esta tool
        .tool-agents-list
          each agent in usedByAgents
            a.tool-agent-chip(href='/agentes/agents/' + agent.id)
              span= agent.icon
              | &nbsp;
              span(data-es=agent.nameEs data-en=agent.name)= agent.nameEs
              span.badge.badge-sm(class='badge-' + agent.type.toLowerCase())= agent.type

  //- Chat flotante
  #tool-chat-fab(title="Consultar sobre esta tool")
    svg(width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
      path(d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z")
  #tool-chat-panel
    #tool-chat-header
      span#tool-chat-title= tool.nameEs
      button#tool-chat-close ✕
    #tool-chat-msgs
      .tool-chat-bubble.bot
        | Hola, soy el asistente de &nbsp;
        strong= tool.nameEs
        | . ¿En qué puedo ayudarte?
    #tool-chat-quick
      button.tool-qa-btn.show-contact(data-type="llamada") 📅 Agendar llamada
      button.tool-qa-btn.show-contact(data-type="correo") ✉️ Enviar correo
    #tool-contact-form(style="display:none")
    #tool-chat-input-row
      input#tool-chat-input(type="text" placeholder="Escribe tu pregunta…")
      button#tool-chat-send Enviar

  script.
    window.TOOL_ID = !{JSON.stringify(tool.id)};
    window.TOOL_NAME_ES = !{JSON.stringify(tool.nameEs)};
    window.TOOL_ISO_ALARMS = !{JSON.stringify(agentIsoAlarms)};
  script(src="/public/agents-tool.js" defer)
