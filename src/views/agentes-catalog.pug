extends layout

block content
  .page-header
    .page-header-inner
      div
        .page-breadcrumb
          a(href="/") Inicio
          svg(width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
            polyline(points="9,18 15,12 9,6")
          span(data-es="Agentes Industriales" data-en="Industrial Agents") Agentes Industriales
        h1.page-title(data-es="Agentes Industriales" data-en="Industrial Agents") Agentes Industriales
        p.page-subtitle(data-es="Explora los agentes de IA industrial: Cloud, Edge e Híbridos. Haz clic en cualquier agente para ver cómo funciona." data-en="Explore industrial AI agents: Cloud, Edge and Hybrid. Click any agent to see how it works.") Explora los agentes de IA industrial: Cloud, Edge e Híbridos. Haz clic en cualquier agente para ver cómo funciona.
      .page-actions
        .catalog-stats
          span.stat-item
            span.stat-num= agents.length
            span.stat-label(data-es=" agentes" data-en=" agents") &nbsp;agentes
          span.stat-sep ·
          span.stat-item
            span.stat-num= agents.filter(a => a.type === 'Cloud').length
            span.stat-label &nbsp;Cloud
          span.stat-sep ·
          span.stat-item
            span.stat-num= agents.filter(a => a.type === 'Edge').length
            span.stat-label &nbsp;Edge
          span.stat-sep ·
          span.stat-item
            span.stat-num= agents.filter(a => a.type === 'Hybrid').length
            span.stat-label(data-es=" Híbridos" data-en=" Hybrid") &nbsp;Híbridos

  main
    .filter-bar
      .filter-buttons
        button.filter-btn.active(data-filter="all" data-es="Todos" data-en="All") Todos
        button.filter-btn(data-filter="Cloud")
          span.badge.badge-cloud Cloud
        button.filter-btn(data-filter="Edge")
          span.badge.badge-edge Edge
        button.filter-btn(data-filter="Hybrid")
          span.badge.badge-hybrid(data-es="Híbrido" data-en="Hybrid") Híbrido
      input.search-input(type="text" placeholder="Buscar agente..." data-placeholder-es="Buscar agente..." data-placeholder-en="Search agent...")

    .agents-grid
      each agent in agents
        a.agent-card(href='/agentes/agents/' + agent.id data-type=agent.type data-name=agent.nameEs.toLowerCase() data-desc=agent.descriptionEs.toLowerCase())
          .agent-card-header
            .agent-card-icon= agent.icon
            span.badge(class='badge-' + agent.type.toLowerCase() data-es=agent.type === 'Hybrid' ? 'Híbrido' : agent.type data-en=agent.type)= agent.type === 'Hybrid' ? 'Híbrido' : agent.type
          h3.agent-card-name
            span(data-es=agent.nameEs data-en=agent.name)= agent.nameEs
          p.agent-card-desc
            span(data-es=agent.descriptionEs data-en=agent.descriptionEn)= agent.descriptionEs
          .agent-card-footer
            .agent-card-tools
              span.tool-count-badge.tool-count-cloud
                svg(width="10" height="10" viewBox="0 0 24 24" fill="currentColor")
                  path(d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z")
                | &nbsp;
                span= agent.toolIds.length
                span(data-es=" tools" data-en=" tools") &nbsp;tools
            if agent.downloadAvailable
              span.download-badge
                svg(width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
                  path(d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4")
                  polyline(points="7,10 12,15 17,10")
                  line(x1="12" y1="15" x2="12" y2="3")
                span(data-es=" Edge disponible" data-en=" Edge available") &nbsp;Edge disponible
          .agent-card-cta
            span.btn.btn-sm.btn-primary(data-es="Ver agente →" data-en="View agent →") Ver agente →

  section.agent-section#demo-section
    h2.section-title
      svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
        polygon(points="13,2 3,14 12,14 11,22 21,10 12,10 13,2")
      span(data-es="Demo Industrial" data-en="Industrial Demo") Demo Industrial
    p(style="color:var(--text-2);font-size:.9rem;margin-bottom:1.5rem;" data-es="Ejecuta 12 herramientas industriales cubriendo 10 ISOs (ISO 9001, IATF 16949, IEC 61511, ISO 45001, ISO 28000, ISO 50001 y más) y genera alarmas reales para verlas en el reporte." data-en="Run 12 industrial tools covering 10 ISOs (ISO 9001, IATF 16949, IEC 61511, ISO 45001, ISO 28000, ISO 50001 and more) and generate real alarms to view in the report.") Ejecuta 12 herramientas industriales cubriendo 10 ISOs (ISO 9001, IATF 16949, IEC 61511, ISO 45001, ISO 28000, ISO 50001 y más) y genera alarmas reales para verlas en el reporte.
    .demo-controls
      button.btn.btn-primary#btn-run-demo
        svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
          polygon(points="5,3 19,12 5,21 5,3")
        span(data-es=" Ejecutar Demo" data-en=" Run Demo") &nbsp;Ejecutar Demo
    .demo-results#demo-results(style="display:none")
      .demo-summary#demo-summary
      .sim-log#demo-log(style="margin-top:1rem")
      .demo-cta#demo-cta(style="margin-top:1.5rem;display:flex;gap:.75rem;flex-wrap:wrap")
        a.btn.btn-primary(href="/integracion-iso" target="_blank")
          span(data-es="Ver en Reporte ISO" data-en="View in ISO Report") Ver en Reporte ISO
          svg(width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5")
            line(x1="5" y1="12" x2="19" y2="12")
            polyline(points="12,5 19,12 12,19")
        a.btn.btn-outline(href="/dashboard" target="_blank")
          span(data-es="Ver Dashboard" data-en="View Dashboard") Ver Dashboard

  script.
    (function() {
      var STORAGE_KEY = 'iso_session_start';
      var EVENTS_KEY  = 'iso_events';

      var DEMO_EVENTS = [
        { module_id:'safety',      asset_id:'robot-01',       severity:'CRITICAL', event_type:'ALARM',   data:{value:91.2, incident_type:'equipment_contact', zone:'Zone-A'} },
        { module_id:'vision',      asset_id:'conveyor-01',    severity:'CRITICAL', event_type:'ALARM',   data:{value:114.3, defect_rate:12.1, unit:'celsius'} },
        { module_id:'maintenance', asset_id:'press-01',       severity:'CRITICAL', event_type:'ALARM',   data:{value:9.1, hours_since_maintenance:4700, oil_pressure:11.2} },
        { module_id:'control',     asset_id:'reactor-01',     severity:'CRITICAL', event_type:'ALARM',   data:{value:98.7, tag:'TIC-101', setpoint:85.0, deviation:13.7, sil_demand:true} },
        { module_id:'energy',      asset_id:'hvac-01',        severity:'HIGH',     event_type:'ALARM',   data:{value:391.5, power_factor:0.63, peak_demand:true} },
        { module_id:'quality',     asset_id:'robot-01',       severity:'HIGH',     event_type:'ALARM',   data:{value:52.3, reject_count:13, batch_id:'BATCH-DEMO-001'} },
        { module_id:'environment', asset_id:'sensor-env-01',  severity:'HIGH',     event_type:'ALARM',   data:{value:1520.0, temperature:34.1, humidity:78.0, unit:'ppm_CO2'} },
        { module_id:'supply_chain',asset_id:'supplier-mx-03', severity:'HIGH',     event_type:'ALARM',   data:{value:0, disruption_risk:'critical', delay_days:8, affected_materials:3} },
        { module_id:'maintenance', asset_id:'robot-02',       severity:'MEDIUM',   event_type:'WARNING', data:{value:4.8, hours_since_maintenance:2300, oil_pressure:44.0} },
        { module_id:'energy',      asset_id:'press-01',       severity:'MEDIUM',   event_type:'WARNING', data:{value:295.0, power_factor:0.71, peak_demand:false} },
        { module_id:'quality',     asset_id:'conveyor-01',    severity:'LOW',      event_type:'INFO',    data:{value:88.5, reject_count:2, batch_id:'BATCH-DEMO-002'} },
        { module_id:'supply_chain',asset_id:'warehouse-01',   severity:'LOW',      event_type:'INFO',    data:{value:94.2, otif_percent:94.2, fill_rate:98.1} },
      ];

      var TOOL_NAMES = !{toolNamesJson};

      var btn  = document.getElementById('btn-run-demo');
      var results = document.getElementById('demo-results');
      var log  = document.getElementById('demo-log');
      var summary = document.getElementById('demo-summary');

      btn.addEventListener('click', function() {
        btn.disabled = true;
        btn.textContent = '⚙ Ejecutando…';
        log.innerHTML = '';
        summary.innerHTML = '';

        var ts = Date.now();
        localStorage.setItem(STORAGE_KEY, ts);
        localStorage.setItem(EVENTS_KEY, '[]');

        var counts = { CRITICAL:0, HIGH:0, MEDIUM:0, LOW:0 };
        var delay = 0;

        DEMO_EVENTS.forEach(function(tpl, i) {
          setTimeout(function() {
            var resolvedAlarm = TOOL_NAMES[tpl.module_id] || tpl.module_id;
            var ev = Object.assign({}, tpl, {
              event_id:  'demo-' + ts + '-' + i,
              timestamp: new Date().toISOString(),
              plant_id:  'PLT-01',
              module_id: resolvedAlarm,
            });
            var events = JSON.parse(localStorage.getItem(EVENTS_KEY) || '[]');
            events.unshift(ev);
            localStorage.setItem(EVENTS_KEY, JSON.stringify(events));
            counts[ev.severity]++;

            var entry = document.createElement('div');
            entry.className = 'log-entry';
            var t = new Date().toLocaleTimeString('es-MX');
            entry.innerHTML =
              '<span class="log-time">' + t + '</span>' +
              '<span class="log-module">' + resolvedAlarm + '</span>' +
              '<span class="log-severity-' + ev.severity + '">' + ev.severity + '</span>' +
              '&nbsp;&nbsp;<span class="log-asset">' + ev.asset_id + ' · ' + ev.event_type + '</span>';
            log.insertBefore(entry, log.firstChild);

            if (i === DEMO_EVENTS.length - 1) {
              summary.innerHTML =
                '<div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:.5rem">' +
                '<span class="badge badge-critical">🔴 ' + counts.CRITICAL + ' Críticas</span>' +
                '<span class="badge badge-high">🟡 ' + counts.HIGH + ' Altas</span>' +
                '<span class="badge badge-medium">🔵 ' + counts.MEDIUM + ' Medias</span>' +
                '<span class="badge badge-low">🟢 ' + counts.LOW + ' Bajas</span>' +
                '</div>' +
                '<p style="color:var(--text-2);font-size:.85rem">12 herramientas ejecutadas · 10 ISOs evaluadas · Eventos guardados en sesión</p>';
              btn.textContent = '✓ Demo ejecutado';
            }
          }, delay);
          delay += 180;
        });

        results.style.display = 'block';
      });
    })();

  section.agent-section
    h2.section-title
      svg(width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
        circle(cx="12" cy="12" r="3")
        path(d="M12 2v4M12 18v4M2 12h4M18 12h4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83")
      span Un Ecosistema Vivo y Conectado
    p.section-sub Los módulos se comunican entre sí para toma de decisiones inteligente
    #eco-catalog-box(style="position:relative;width:100%;height:clamp(320px,55vh,520px);margin-top:1.5rem")
      svg#eco-catalog-svg(style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1;overflow:visible")
      .eco-node#eco-gateway(style="left:2%;top:10%;border-color:#60A5FA;color:#93C5FD")
        .eco-icon 🔌
        | Gateway OT-IT
      .eco-node#eco-vision(style="left:2%;top:36%;border-color:#A78BFA;color:#C4B5FD")
        .eco-icon 👁️
        | Visión Artificial
      .eco-node#eco-fallas(style="left:2%;top:62%;border-color:#F59E0B;color:#FCD34D")
        .eco-icon 📳
        | Fallas Mecánicas
      .eco-node#eco-energia(style="left:2%;top:82%;border-color:#22D3EE;color:#67E8F9")
        .eco-icon ⚡
        | Energía con AI
      .eco-node#eco-digitwin(style="left:23%;top:5%;border-color:#FBBF24;color:#FDE68A")
        .eco-icon 🪞
        | Digital Twin
      .eco-node#eco-conteo(style="left:23%;top:78%;border-color:#A78BFA;color:#C4B5FD")
        .eco-icon 🔢
        | Conteo en Banda
      #eco-nucleo(style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:clamp(80px,9vw,115px);height:clamp(80px,9vw,115px);border-radius:50%;background:radial-gradient(circle,#1D4ED8,#1E3A8A);border:3px solid #60A5FA;display:flex;align-items:center;justify-content:center;flex-direction:column;font-weight:700;color:#BFDBFE;text-align:center;font-size:clamp(7px,.75vw,11px);box-shadow:0 0 30px rgba(37,99,235,.6),0 0 60px rgba(37,99,235,.3);animation:eco-glow 2s ease infinite;z-index:10;padding:6px") 🧠
        br
        | NÚCLEO
        br
        | CENTRAL
      .eco-node#eco-scrap(style="right:23%;top:5%;border-color:#F87171;color:#FCA5A5")
        .eco-icon 🗑️
        | Scrap & Calidad
      .eco-node#eco-erp(style="right:23%;top:78%;border-color:#34D399;color:#6EE7B7")
        .eco-icon 🏢
        | SAP / ERP
      .eco-node#eco-analitica(style="right:2%;top:10%;border-color:#22D3EE;color:#67E8F9")
        .eco-icon 📈
        | Analítica & KPIs
      .eco-node#eco-inventario(style="right:2%;top:36%;border-color:#34D399;color:#6EE7B7")
        .eco-icon 📦
        | Inventario Inteligente
      .eco-node#eco-produccion(style="right:2%;top:62%;border-color:#F87171;color:#FCA5A5")
        .eco-icon 📊
        | Prod. Real vs Plan
      .eco-node#eco-crm(style="right:2%;top:82%;border-color:#FBBF24;color:#FDE68A")
        .eco-icon 🤝
        | CRM Industrial
      #eco-fdot(style="position:absolute;width:13px;height:13px;border-radius:50%;background:#A78BFA;box-shadow:0 0 10px #A78BFA;display:none;z-index:20;transition:left .7s ease,top .7s ease,background .3s;pointer-events:none")

  style.
    .eco-node{position:absolute;border-radius:10px;background:rgba(10,20,40,.95);border:2px solid;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:clamp(7px,.65vw,11px);font-weight:600;text-align:center;padding:.5rem .6rem;cursor:default;z-index:5;transition:transform .25s;width:clamp(75px,8.5vw,120px);line-height:1.3}
    .eco-node:hover{transform:scale(1.06)}
    .eco-icon{font-size:clamp(14px,1.4vw,22px);margin-bottom:.2rem}
    #eco-catalog-svg .eco-line{stroke-dasharray:8 5;animation:eco-dash 2s linear infinite;fill:none;stroke-width:1.5;opacity:.5}
    @keyframes eco-dash{from{stroke-dashoffset:26}to{stroke-dashoffset:0}}
    @keyframes eco-glow{0%,100%{box-shadow:0 0 28px rgba(37,99,235,.5)}50%{box-shadow:0 0 55px rgba(37,99,235,.9)}}
    .section-sub{color:var(--text-2);font-size:.9rem;margin-top:.25rem}

  script.
    (function() {
      function ecoCenter(el) {
        var box = el.getBoundingClientRect();
        var pb = document.getElementById('eco-catalog-box').getBoundingClientRect();
        return { x: box.left - pb.left + box.width/2, y: box.top - pb.top + box.height/2 };
      }
      function ecoDrawLines() {
        var svg = document.getElementById('eco-catalog-svg');
        if (!svg) return;
        svg.innerHTML = '';
        var nucleus = document.getElementById('eco-nucleo');
        if (!nucleus) return;
        var nc = ecoCenter(nucleus);
        var nodes = ['eco-gateway','eco-vision','eco-fallas','eco-energia','eco-digitwin','eco-conteo','eco-scrap','eco-erp','eco-analitica','eco-inventario','eco-produccion','eco-crm'];
        var colors = ['#60A5FA','#A78BFA','#F59E0B','#22D3EE','#FBBF24','#A78BFA','#F87171','#34D399','#22D3EE','#34D399','#F87171','#FBBF24'];
        var crossPairs = [
          ['eco-gateway','eco-digitwin','#60A5FA'],
          ['eco-vision','eco-conteo','#A78BFA'],
          ['eco-vision','eco-scrap','#A78BFA'],
          ['eco-analitica','eco-erp','#22D3EE'],
          ['eco-produccion','eco-scrap','#F87171'],
          ['eco-inventario','eco-erp','#34D399'],
          ['eco-fallas','eco-produccion','#F59E0B'],
          ['eco-energia','eco-analitica','#22D3EE']
        ];
        crossPairs.forEach(function(pair) {
          var el1 = document.getElementById(pair[0]);
          var el2 = document.getElementById(pair[1]);
          if (!el1 || !el2) return;
          var c1 = ecoCenter(el1), c2 = ecoCenter(el2);
          var ln = document.createElementNS('http://www.w3.org/2000/svg','line');
          ln.setAttribute('x1',c1.x); ln.setAttribute('y1',c1.y);
          ln.setAttribute('x2',c2.x); ln.setAttribute('y2',c2.y);
          ln.setAttribute('stroke',pair[2]);
          ln.setAttribute('class','eco-line');
          ln.setAttribute('style','opacity:0.2');
          svg.appendChild(ln);
        });
        nodes.forEach(function(id, i) {
          var el = document.getElementById(id);
          if (!el) return;
          var ec = ecoCenter(el);
          var line = document.createElementNS('http://www.w3.org/2000/svg','line');
          line.setAttribute('x1',ec.x); line.setAttribute('y1',ec.y);
          line.setAttribute('x2',nc.x); line.setAttribute('y2',nc.y);
          line.setAttribute('stroke',colors[i]);
          line.setAttribute('class','eco-line');
          svg.appendChild(line);
        });
      }
      var ecoNodeIds = ['eco-gateway','eco-vision','eco-fallas','eco-energia','eco-digitwin','eco-conteo','eco-scrap','eco-erp','eco-analitica','eco-inventario','eco-produccion','eco-crm'];
      var ecoDotColors = ['#60A5FA','#A78BFA','#F59E0B','#22D3EE','#FBBF24','#A78BFA','#F87171','#34D399','#22D3EE','#34D399','#F87171','#FBBF24'];
      var ecoDotIdx = 0, ecoDotPhase = 0;
      function ecoMoveDot() {
        var fdot = document.getElementById('eco-fdot');
        var box = document.getElementById('eco-catalog-box');
        if (!fdot || !box) return;
        fdot.style.display = 'block';
        var nodeEl = document.getElementById(ecoNodeIds[ecoDotIdx]);
        var nucleus = document.getElementById('eco-nucleo');
        if (!nodeEl || !nucleus) return;
        var nc = ecoCenter(nucleus), ec = ecoCenter(nodeEl);
        var target = ecoDotPhase === 0 ? nc : ec;
        fdot.style.background = ecoDotColors[ecoDotIdx];
        fdot.style.boxShadow = '0 0 10px ' + ecoDotColors[ecoDotIdx];
        fdot.style.left = (target.x - 6.5) + 'px';
        fdot.style.top = (target.y - 6.5) + 'px';
        if (ecoDotPhase === 0) { ecoDotPhase = 1; }
        else { ecoDotPhase = 0; ecoDotIdx = (ecoDotIdx + 1) % ecoNodeIds.length; }
      }
      window.addEventListener('load', function() {
        setTimeout(function() {
          ecoDrawLines();
          ecoMoveDot();
          setInterval(ecoMoveDot, 900);
        }, 400);
      });
      window.addEventListener('resize', ecoDrawLines);
    })();

  script(src="/public/agents-catalog.js" defer)
